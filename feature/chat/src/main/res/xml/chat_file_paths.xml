<?xml version="1.0" encoding="utf-8"?>
<!-- 文件：feature/chat/src/main/res/xml/chat_file_paths.xml -->
<!-- 说明：限定 FileProvider 可共享的缓存目录 -->
<paths>
    <cache-path name="chat_exports" path="chat/exports/" />
    <!-- 重要：仅允许分享 app 私有 filesDir/xfyun_raw/ 下的讯飞 raw dump 文件 -->
    <files-path name="xfyun_raw_dumps" path="xfyun_raw/" />
    <!-- 重要：仅允许分享 app 私有 filesDir/tingwu_raw/ 下的听悟 raw dump 文件 -->
    <files-path name="tingwu_raw_dumps" path="tingwu_raw/" />
</paths>
