          "$ref": "#/$defs/TimestampMs"
        },
        "endMs": {
          "$ref": "#/$defs/TimestampMs"
        },
        "timeRange": {
          "type": "object",
          "additionalProperties": false,
          "description": "Absolute milliseconds on recording timeline; 0ms = recording start; half-open interval [startMs, endMs).",
          "required": [
            "startMs",
            "endMs"
          ],
          "properties": {
            "startMs": {
              "$ref": "#/$defs/TimestampMs",
              "description": "Absolute milliseconds since recording start (inclusive)."
            },
            "endMs": {
              "$ref": "#/$defs/TimestampMs",
              "description": "Absolute milliseconds since recording start (exclusive)."
            }
          }
        },
        "audioAssetId": {
          "$ref": "#/$defs/AudioAssetId"
        },
        "recordingSessionId": {
          "$ref": "#/$defs/RecordingSessionId"
        }
      }
    },
    "M2BKeyPoint": {
      "type": "object",
      "additionalProperties": false,
      "description": "Key point with required source pointers (chapterId and/or timeRange).",
      "required": [
        "text",
        "audioAssetId",
        "recordingSessionId"
      ],
      "anyOf": [
        {
          "required": ["chapterId"]
        },
        {
          "required": ["timeRange"]
        }
      ],
      "properties": {
        "text": {
          "type": "string"
        },
        "chapterId": {
          "type": "string"
        },
        "timeRange": {
          "type": "object",
          "additionalProperties": false,
          "description": "Absolute milliseconds on recording timeline; 0ms = recording start; half-open interval [startMs, endMs).",
          "required": [
            "startMs",
            "endMs"
          ],
          "properties": {
            "startMs": {
              "$ref": "#/$defs/TimestampMs",
              "description": "Absolute milliseconds since recording start (inclusive)."
            },
            "endMs": {
              "$ref": "#/$defs/TimestampMs",
              "description": "Absolute milliseconds since recording start (exclusive)."
            }
          }
        },
        "audioAssetId": {
          "$ref": "#/$defs/AudioAssetId"
        },
        "recordingSessionId": {
          "$ref": "#/$defs/RecordingSessionId"
        }
      }
    },
