#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

MAP_FILE="docs/cerb/interface-map.md"
HTML_FILE="docs/cerb/dashboard.html"
GENERATOR_SCRIPT="docs/tools/generate_map.py"

python3 scripts/lane_guard.py validate-worktree --mode staged

if git diff --cached --name-only | grep -q "^${MAP_FILE}$"; then
  echo "[lane-harness] ${MAP_FILE} changed, regenerating dashboard"
  python3 "$GENERATOR_SCRIPT"
  git add "$HTML_FILE"
fi
