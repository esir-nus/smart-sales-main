{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartsales.local/schemas/third-party-registry.v1.schema.json",
  "title": "SmartSales Third-Party Integration Registry Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "doc", "generatedFrom", "index"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "minLength": 1 },
    "doc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "purpose", "audience", "scope", "nonGoals", "trustModel"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "audience": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "scope": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "nonGoals": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "trustModel": { "type": "string", "minLength": 1 }
      }
    },
    "generatedFrom": {
      "type": "object",
      "additionalProperties": true,
      "required": ["repoRoot", "branch", "commit", "generatedAt"],
      "properties": {
        "repoRoot": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string", "minLength": 1 }
      }
    },
    "index": {
      "type": "object",
      "additionalProperties": false,
      "required": ["areas", "symbols"],
      "properties": {
        "areas": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "jsonPointer"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "jsonPointer": { "type": "string", "pattern": "^/" },
              "keywords": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "symbols": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["name", "file", "kind", "searchTerms"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "file": { "type": "string", "minLength": 1 },
              "kind": { "type": "string", "enum": ["function", "class", "object", "const"] },
              "searchTerms": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
            }
          }
        }
      }
    },
    "oss": { "type": "object", "additionalProperties": true },
    "tingwu": { "type": "object", "additionalProperties": true },
    "xfyun": {
      "type": "object",
      "additionalProperties": true,
      "required": ["baseUrl", "endpoints", "signature", "guardrails"],
      "properties": {
        "baseUrl": { "type": "string", "minLength": 1 },
        "endpoints": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": true, "required": ["id", "method", "path"] } },
        "signature": { "type": "object", "additionalProperties": true },
        "guardrails": {
          "type": "object",
          "additionalProperties": false,
          "required": ["transferOnly"],
          "properties": {
            "transferOnly": { "type": "boolean" },
            "notes": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "dashscope": { "type": "object", "additionalProperties": true },
    "placeholders": { "type": "object", "additionalProperties": true }
  }
}

