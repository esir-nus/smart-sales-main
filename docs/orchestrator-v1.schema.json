{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartsales.local/schemas/orchestrator-v1.schema.json",
  "title": "Orchestrator-V1 JSON Schema",
  "description": "Schema for Orchestrator-V1 data models defined in docs/Orchestrator-V1.md. Macro windows are half-open [absStartMs, absEndMs); pre-roll overlap only; ordering uses batchIndex (integer). Chat uses dual-channel output: <visible2user> as human channel and MachineArtifact as machine channel.",
  "$comment": "CURRENT. Spec: docs/Orchestrator-V1.md. SchemaVersion: 1 (integer). Idempotency keys: Parsing-contract objects (MachineArtifact + M1..M4 + M2BTranscriptionState): (chatSessionId/audioAssetId, turnId/recordingSessionId, artifactType, schemaVersion). Domain artifacts (DisectorPlan/TingwuJobState/TingwuBatchArtifact/PublisherState/Published*): (audioAssetId, recordingSessionId, batchIndex, artifactType, version). Schema enforces types and required fields; behavioral invariants are documented in the spec.",
  "xIndex": {
    "purpose": "Orchestrator-V1 architecture models SoT",
    "currentSpec": "docs/Orchestrator-V1.md",
    "invariants": [
      "batchIndex is ordering primitive",
      "pre-roll only",
      "range filtering",
      "chapter offset anchored to captureStartMs"
    ],
    "idempotencyKeyParsing": {
      "recording": "(audioAssetId, recordingSessionId, artifactType, schemaVersion)",
      "chat": "(chatSessionId, turnId, artifactType, schemaVersion)"
    },
    "idempotencyKeyArtifact": {
      "recording": "(audioAssetId, recordingSessionId, batchIndex, artifactType, version)",
      "chat": "(chatSessionId, turnId, artifactType, version)"
    },
    "payloadTypes": [
      "DisectorPlan",
      "TingwuJobState",
      "TingwuBatchArtifact",
      "PublisherState",
      "PublishedTranscript",
      "PublishedAnalysis",
      "PublishedChatTurn",
      "MachineArtifact",
      "M1UserMetadata",
      "M2ConversationState",
      "M2BTranscriptionState",
      "M3SessionState",
      "M4ExternalKnowledge"
    ],
    "deprecatedPayloadTypes": [
      "SessionMemory"
    ]
  },
  "xAgentGuidance": {
    "whenToRead": [
      "Generating MachineArtifact or SmartAnalysis from LLM output",
      "Parsing Tingwu response into TingwuBatchArtifact",
      "Validating DisectorPlan before transcription",
      "Understanding M1-M4 metadata layer structure",
      "Building PublishedChatTurn with artifactStatus"
    ],
    "whenNotToRead": [
      "UI-level concerns (use docs/ux-contract.md instead)",
      "Domain coordinator interfaces (use docs/api-contracts.md instead)",
      "Third-party provider details (use docs/source-repo.json instead)",
      "V1 behavioral invariants (use docs/Orchestrator-V1.md instead)"
    ],
    "startWith": [
      "xIndex.payloadTypes for list of active types",
      "xIndex.deprecatedPayloadTypes to know what to avoid",
      "xIndex.invariants for ordering and filtering rules"
    ],
    "keyTypes": {
      "forChat": ["PublishedChatTurn", "MachineArtifact", "SmartAnalysisCard", "ChatMode", "ArtifactStatus"],
      "forTranscription": ["DisectorPlan", "DisectorBatch", "TingwuBatchArtifact", "PublishedTranscript", "PublishedAnalysis"],
      "forMetadata": ["M1UserMetadata", "M2ConversationState", "M2BTranscriptionState", "M3SessionState", "M4ExternalKnowledge"],
      "forIds": ["AudioAssetId", "RecordingSessionId", "ChatSessionId", "TurnId", "BatchIndex", "BatchAssetId"]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/SinglePayload"
    },
    {
      "$ref": "#/$defs/PayloadArray"
    },
    {
      "$ref": "#/$defs/ExamplesFile"
    }
  ],
  "$defs": {
    "SinglePayload": {
      "oneOf": [
        {
          "$ref": "#/$defs/DisectorPlan"
        },
        {
          "$ref": "#/$defs/TingwuJobState"
        },
        {
          "$ref": "#/$defs/TingwuBatchArtifact"
        },
        {
          "$ref": "#/$defs/SessionMemory"
        },
        {
          "$ref": "#/$defs/PublisherState"
        },
        {
          "$ref": "#/$defs/PublishedTranscript"
        },
        {
          "$ref": "#/$defs/PublishedAnalysis"
        },
        {
          "$ref": "#/$defs/PublishedChatTurn"
        },
        {
          "$ref": "#/$defs/MachineArtifact"
        },
        {
          "$ref": "#/$defs/M1UserMetadata"
        },
        {
          "$ref": "#/$defs/M2ConversationState"
        },
        {
          "$ref": "#/$defs/M2BTranscriptionState"
        },
        {
          "$ref": "#/$defs/M3SessionState"
        },
        {
          "$ref": "#/$defs/M4ExternalKnowledge"
        }
      ]
    },
    "PayloadArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/SinglePayload"
      }
    },
    "ExamplesFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "xIndex",
        "payloads"
      ],
      "properties": {
        "xIndex": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "purpose",
            "payloads"
          ],
          "properties": {
            "purpose": {
              "type": "string",
              "minLength": 1
            },
            "payloads": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "howToUse": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          }
        },
        "payloads": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/SinglePayload"
          }
        }
      }
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "TimestampMs": {
      "type": "integer",
      "minimum": 0
    },
    "BatchIndex": {
      "type": "integer",
      "minimum": 1,
      "description": "Ordering primitive; numeric sort only."
    },
    "BatchId": {
      "type": "string",
      "pattern": "^b[1-9]\\d*$",
      "description": "Stable identifier derived from batchIndex; display only; not used for ordering."
    },
    "DisectorBatch": {
      "type": "object",
      "additionalProperties": false,
      "description": "Batch time ranges: absStartMs..absEndMs define macro window (half-open). captureStartMs may include pre-roll; captureEndMs must equal absEndMs.",
      "required": [
        "batchIndex",
        "batchAssetId",
        "absStartMs",
        "absEndMs",
        "captureStartMs",
        "captureEndMs",
        "durationMs"
      ],
      "properties": {
        "batchIndex": {
          "$ref": "#/$defs/BatchIndex"
        },
        "batchId": {
          "$ref": "#/$defs/BatchId"
        },
        "absStartMs": {
          "$ref": "#/$defs/TimestampMs",
          "description": "Macro window start (inclusive)."
        },
        "absEndMs": {
          "$ref": "#/$defs/TimestampMs",
          "description": "Macro window end (exclusive)."
        },
        "captureStartMs": {
          "$ref": "#/$defs/TimestampMs",
          "description": "Capture start; may be earlier than absStartMs for pre-roll.",
          "minimum": 0
        },
        "captureEndMs": {
          "$ref": "#/$defs/TimestampMs",
          "description": "Capture end; must equal absEndMs (no post-roll)."
        },
        "durationMs": {
          "$ref": "#/$defs/TimestampMs"
        },
        "batchAssetId": {
          "$ref": "#/$defs/BatchAssetId"
        }
      }
    },
    "DisectorPlan": {
      "type": "object",
      "additionalProperties": false,
      "description": "Deterministic batch plan. overlapMs is fixed to 10s in V1. Use batchIndex for ordering.",
      "required": [
        "artifactType",
        "audioAssetId",
        "recordingSessionId",
        "disectorPlanId",
        "version",
        "totalMs",
        "overlapMs",
        "batches"
      ],
      "properties": {
        "artifactType": {
          "type": "string",
          "const": "DisectorPlan"
        },
        "sessionId": {
          "$ref": "#/$defs/NonEmptyString",
          "description": "DEPRECATED alias of recordingSessionId. Agents must not emit sessionId in new payloads."
        },
        "version": {
          "type": "integer",
          "const": 1,
          "description": "V1 schema version."
        },
        "totalMs": {
          "$ref": "#/$defs/TimestampMs"
        },
        "overlapMs": {
          "type": "integer",
          "const": 10000,
          "description": "Pre-roll overlap only; non-first batches start at absStartMs - overlapMs."
        },
        "batches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DisectorBatch"
          },
          "minItems": 1
        },
        "recordingSessionId": {
          "$ref": "#/$defs/RecordingSessionId"
        },
        "audioAssetId": {
          "$ref": "#/$defs/AudioAssetId"
        },
        "disectorPlanId": {
          "$ref": "#/$defs/DisectorPlanId"
        }
      }
    },
    "TingwuJobState": {
      "type": "object",
      "additionalProperties": false,
      "description": "Persisted status for a Tingwu job per batch.",
      "required": [
        "artifactType",
        "audioAssetId",
        "recordingSessionId",
        "version",
        "batchIndex",
        "status",
        "attemptCount"
      ],
      "properties": {
        "artifactType": {
          "type": "string",
          "const": "TingwuJobState"
        },
        "sessionId": {
          "$ref": "#/$defs/NonEmptyString",
          "description": "DEPRECATED alias of recordingSessionId. Agents must not emit sessionId in new payloads."
        },
        "version": {
          "type": "integer",
          "const": 1
        },
        "batchIndex": {
          "$ref": "#/$defs/BatchIndex"
        },
        "batchId": {
          "$ref": "#/$defs/BatchId"
        },
        "status": {
          "type": "string",
          "enum": [
            "PLANNED",
            "SUBMITTED",
            "RUNNING",
            "SUCCEEDED",
            "FAILED"
          ]
        },
        "attemptCount": {
          "type": "integer",
          "minimum": 0
        },
        "lastErrorCategory": {
          "type": "string",
          "enum": [
            "NONE",
            "NETWORK",
            "TIMEOUT",
            "RATE_LIMIT",
            "AUTH",
            "INPUT",
            "PROVIDER",
            "UNKNOWN"
          ],
          "default": "NONE"
        },
        "lastErrorStatusCode": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "retryBackoffSeconds": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "recordingSessionId": {
          "$ref": "#/$defs/RecordingSessionId"
        },
        "audioAssetId": {
          "$ref": "#/$defs/AudioAssetId"
        },
        "batchAssetId": {
          "$ref": "#/$defs/BatchAssetId"
        }
      }
    },
    "RelativeSegment": {
      "type": "object",
      "additionalProperties": false,
      "description": "Relative segment times are relative to captureStartMs, not absStartMs. Absolute time = captureStartMs + relStartMs.",
      "required": [
        "relStartMs",
        "text"
      ],
      "properties": {
        "relStartMs": {
          "$ref": "#/$defs/TimestampMs"
        },
        "relEndMs": {
          "$ref": "#/$defs/TimestampMs"
        },
        "speakerKey": {
          "type": "string"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "TingwuTranscription": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string"
        },
        "relativeSegments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RelativeSegment"
          },
          "default": []
        }
      }
    },
    "TingwuSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string"
        }
      }
    },
    "TingwuChapter": {
      "type": "object",
      "additionalProperties": false,
      "description": "offsetMs is relative to captureStartMs; published chapters must fall within macro window or fall back to batch.absStartMs.",
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "offsetMs": {
          "$ref": "#/$defs/TimestampMs"
        },
        "durationMs": {
          "$ref": "#/$defs/TimestampMs"
        }
      }
    },
    "TingwuBatchArtifact": {
      "type": "object",
      "additionalProperties": false,
      "description": "Batch artifacts returned by Tingwu: transcription (with optional relative segments), summary, chapters.",
      "required": [
        "artifactType",
        "audioAssetId",
        "recordingSessionId",
        "version",
        "batchIndex",
        "jobId",
        "transcription",
        "summary",
        "chapters"
      ],
      "properties": {
        "artifactType": {
          "type": "string",
          "const": "TingwuBatchArtifact"
        },
        "sessionId": {
          "$ref": "#/$defs/NonEmptyString",
          "description": "DEPRECATED alias of recordingSessionId. Agents must not emit sessionId in new payloads."
        },
        "version": {
          "type": "integer",
          "const": 1
        },
        "batchIndex": {
          "$ref": "#/$defs/BatchIndex"
        },
        "batchId": {
          "$ref": "#/$defs/BatchId"
        },
        "jobId": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "transcription": {
          "$ref": "#/$defs/TingwuTranscription"
        },
        "summary": {
          "$ref": "#/$defs/TingwuSummary"
        },
        "chapters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TingwuChapter"
          },
          "default": []
        },
        "recordingSessionId": {
          "$ref": "#/$defs/RecordingSessionId"
        },
        "audioAssetId": {
          "$ref": "#/$defs/AudioAssetId"
        },
        "batchAssetId": {
          "$ref": "#/$defs/BatchAssetId"
        }
      }
    },
    "SpeakerMapEntry": {
      "type": "object",
      "additionalProperties": false,
      "description": "Speaker mapping evolves by batch; effectiveFromBatchId marks the first batch where mapping applies.",
      "required": [
        "speakerKey",
        "displayName",
        "confidence",
        "effectiveFromBatchIndex"
      ],
      "properties": {
        "speakerKey": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "effectiveFromBatchIndex": {
          "$ref": "#/$defs/BatchIndex"
        },
        "effectiveFromBatchId": {
          "$ref": "#/$defs/BatchId"
        }
      }
    },
    "BatchSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "batchIndex",
        "summary"
      ],
      "properties": {
        "batchIndex": {
          "$ref": "#/$defs/BatchIndex"
        },
        "batchId": {
          "$ref": "#/$defs/BatchId"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "MemoryChapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "absStartMs",
        "batchIndex"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "absStartMs": {
          "$ref": "#/$defs/TimestampMs"
        },
        "absEndMs": {
          "$ref": "#/$defs/TimestampMs"
        },
        "batchIndex": {
          "$ref": "#/$defs/BatchIndex"
        },
        "batchId": {
          "$ref": "#/$defs/BatchId"
        }
      }
    },
    "SessionMemory": {
      "$comment": "DEPRECATED: use M2BTranscriptionState. This type is maintained for backward compatibility only.",
      "type": "object",
      "additionalProperties": false,
      "description": "DEPRECATED: Structured memory derived from Tingwu summaries and chapters; chapter timestamps are chapter-level only. Use M2BTranscriptionState instead.",
      "required": [
        "artifactType",
        "audioAssetId",
        "recordingSessionId",
        "version",
        "schemaVersion",
        "speakerMap",
        "chapters"
      ],
      "properties": {
        "artifactType": {
          "type": "string",
          "const": "SessionMemory"
        },
        "sessionId": {
          "$ref": "#/$defs/NonEmptyString",
          "description": "DEPRECATED alias of recordingSessionId. Agents must not emit sessionId in new payloads."
        },
        "version": {
          "type": "integer",
          "const": 1
        },
        "schemaVersion": {
          "type": "integer",
          "const": 1
        },
        "updatedAtMs": {
          "$ref": "#/$defs/TimestampMs"
        },
        "speakerMap": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SpeakerMapEntry"
          },
          "default": []
        },
        "chapters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MemoryChapter"
          },
          "default": []
        },
        "batchSummaries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BatchSummary"
          },
          "default": []
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "nextSteps": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "recordingSessionId": {
          "$ref": "#/$defs/RecordingSessionId"
        },
        "audioAssetId": {
          "$ref": "#/$defs/AudioAssetId"
        }
      }
    },
    "PublisherState": {
      "type": "object",
      "additionalProperties": false,
      "description": "Published prefix state; publishedPrefixBatchIndex is monotonic and advances only for contiguous batches.",
      "required": [
        "artifactType",
        "audioAssetId",
        "recordingSessionId",
        "version",
        "publishedPrefixBatchIndex"
      ],
      "properties": {
        "artifactType": {
          "type": "string",
          "const": "PublisherState"
        },
        "sessionId": {
          "$ref": "#/$defs/NonEmptyString",
          "description": "DEPRECATED alias of recordingSessionId. Agents must not emit sessionId in new payloads."
        },
        "version": {
          "type": "integer",
          "const": 1
        },
        "publishedPrefixBatchIndex": {
          "type": "integer",
          "minimum": 0
        },
        "recordingSessionId": {
          "$ref": "#/$defs/RecordingSessionId"
        },
        "audioAssetId": {
          "$ref": "#/$defs/AudioAssetId"
        }
      }
    },
    "PublishedUtterance": {
      "type": "object",
      "additionalProperties": false,
      "description": "Published utterance line with absolute timestamps derived from captureStartMs + relative times.",
      "required": [
        "absStartMs",
        "speakerKey",
        "speakerDisplay",
        "text",
        "batchIndex"
      ],
      "properties": {
        "absStartMs": {
          "$ref": "#/$defs/TimestampMs"
        },
        "absEndMs": {
          "$ref": "#/$defs/TimestampMs"
        },
        "speakerKey": {
          "type": "string"
        },
        "speakerDisplay": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "batchIndex": {
          "$ref": "#/$defs/BatchIndex"
        },
        "batchId": {
          "$ref": "#/$defs/BatchId"
        }
      }
    },
    "PublishedTranscript": {
      "type": "object",
      "additionalProperties": false,
      "description": "Published transcript; items are range-filtered to macro window overlap.",
      "required": [
        "artifactType",
        "audioAssetId",
        "recordingSessionId",
        "version",
        "publishedPrefixBatchIndex",
        "items"
      ],
      "properties": {
        "artifactType": {
          "type": "string",
          "const": "PublishedTranscript"
        },
        "sessionId": {
          "$ref": "#/$defs/NonEmptyString",
          "description": "DEPRECATED alias of recordingSessionId. Agents must not emit sessionId in new payloads."
        },
        "version": {
          "type": "integer",
          "const": 1
        },
        "publishedPrefixBatchIndex": {
          "type": "integer",
          "minimum": 0
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PublishedUtterance"
          },
          "default": []
        },
        "recordingSessionId": {
          "$ref": "#/$defs/RecordingSessionId"
        },
        "audioAssetId": {
          "$ref": "#/$defs/AudioAssetId"
        }
      }
    },
    "PublishedAnalysisChapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "absStartMs"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "absStartMs": {
          "$ref": "#/$defs/TimestampMs"
        },
        "absEndMs": {
          "$ref": "#/$defs/TimestampMs"
        }
      }
    },
    "PublishedAnalysis": {
      "type": "object",
      "additionalProperties": false,
      "description": "Published analysis view; chapter timeline and speaker map are derived from M2BTranscriptionState (M2B).",
      "required": [
        "artifactType",
        "audioAssetId",
        "recordingSessionId",
        "version",
        "summary",
        "chapters",
        "speakerMap"
      ],
      "properties": {
        "artifactType": {
          "type": "string",
          "const": "PublishedAnalysis"
        },
        "sessionId": {
          "$ref": "#/$defs/NonEmptyString",
          "description": "DEPRECATED alias of recordingSessionId. Agents must not emit sessionId in new payloads."
        },
        "version": {
          "type": "integer",
          "const": 1
        },
        "summary": {
          "type": "string"
        },
        "chapters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PublishedAnalysisChapter"
          },
          "default": []
        },
        "speakerMap": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SpeakerMapEntry"
          },
          "default": []
        },
        "recordingSessionId": {
          "$ref": "#/$defs/RecordingSessionId"
        },
        "audioAssetId": {
          "$ref": "#/$defs/AudioAssetId"
        }
      }
    },
    "IdString": {
      "type": "string",
      "minLength": 1
    },
    "AudioAssetId": {
      "type": "string",
      "minLength": 1,
      "description": "Content identity for an audio asset (dedupe key)."
    },
    "RecordingSessionId": {
      "type": "string",
      "minLength": 1,
      "description": "Processing instance id for a recording (may be new even if audioAssetId is cached)."
    },
    "DisectorPlanId": {
      "type": "string",
      "minLength": 1,
      "description": "Identity for the Disector plan (bound to rule version)."
    },
    "BatchAssetId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable id for a batch produced by DisectorPlan."
    },
    "ChatSessionId": {
      "type": "string",
      "minLength": 1,
      "description": "Chat session id."
    },
    "TurnId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique id for a chat turn/message."
    },
    "ChatMode": {
      "type": "string",
      "enum": [
        "L1",
        "L2",
        "L3"
      ]
    },
    "ArtifactStatus": {
      "type": "string",
      "enum": [
        "VALID",
        "INVALID",
        "RETRIED",
        "FAILED"
      ]
    },
    "MachineArtifactProvenance": {
      "type": "object",
