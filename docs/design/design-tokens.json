{
  "theme": {
    "name": "Sleek Glass (Pro Max)",
    "colors": {
      "bg-app": "#F5F5F7",
      "bg-surface": "rgba(255, 255, 255, 0.70)",
      "bg-surface-frosted": "rgba(255, 255, 255, 0.65)",
      "color-accent": "#000000",
      "color-accent-blue": "#007AFF",
      "color-accent-purple": "#AF52DE",
      "color-text-primary": "#1D1D1F",
      "color-text-secondary": "#86868B",
      "color-text-muted": "#AEAEB2",
      "color-danger-surface": "#FEF2F2",
      "color-danger-text": "#DC2626"
    },
    "borders": {
      "base": "rgba(0, 0, 0, 0.04)",
      "width": "0.5px"
    },
    "shadows": {
      "glass": "0 20px 40px -10px rgba(0, 0, 0, 0.05)",
      "capsule": "0 8px 24px rgba(0, 122, 255, 0.15)"
    },
    "radii": {
      "card": "20px",
      "capsule": "9999px",
      "button": "12px"
    },
    "typography": {
      "font-spacing": "-0.02em",
      "font-family-en": "Inter, system-ui",
      "font-family-cn": "PingFang SC, system-ui"
    },
    "spacing": {
      "grid": "4px",
      "base": "16px",
      "layout-gutters": "16px",
      "touch-target": "48px"
    }
  }
}
