{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartsales.local/schemas/metahub-schema-v7.json",
  "$comment": "ARCHIVED: replaced by Orchestrator-V1 JSON set (docs/orchestrator-v1.schema.json). This schema is preserved for historical reference only.",
  "title": "SmartSales MetaHub Schema V7",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sessionId", "m1", "m2", "m3", "m4"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "7.0.0" },
    "sessionId": { "type": "string", "minLength": 1 },
    "m1": { "$ref": "#/$defs/UserMetadata" },
    "m2": { "$ref": "#/$defs/ConversationDerivedState" },
    "m3": { "$ref": "#/$defs/SessionState" },
    "m4": { "$ref": "#/$defs/ExternalKnowledgeAndStyle" }
  },
  "$defs": {
    "TimestampMs": { "type": "integer", "minimum": 0 },
    "EvidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "type": "string", "enum": ["utteranceIndex", "batchId", "messageId", "providerSegmentId", "freeText"] },
        "value": { "type": "string" }
      }
    },
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "updatedAt"],
      "properties": {
        "source": { "type": "string" },
        "updatedAt": { "$ref": "#/$defs/TimestampMs" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidenceRefs": { "type": "array", "items": { "$ref": "#/$defs/EvidenceRef" }, "default": [] }
      }
    },
    "UserMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "updatedAt", "payload"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "updatedAt": { "$ref": "#/$defs/TimestampMs" },
        "payload": { "type": "object", "additionalProperties": true },
        "polishContext": { "type": "object", "additionalProperties": true }
      }
    },
    "DerivedEnumWithProv": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "prov"],
      "properties": {
        "value": { "type": "string" },
        "prov": { "$ref": "#/$defs/Provenance" }
      }
    },
    "DerivedTextList": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items", "prov"],
      "properties": {
        "items": { "type": "array", "items": { "type": "string" }, "default": [] },
        "prov": { "$ref": "#/$defs/Provenance" }
      }
    },
    "RawSignals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dealRiskLevel": { "$ref": "#/$defs/DerivedEnumWithProv" },
        "stage": { "$ref": "#/$defs/DerivedEnumWithProv" },
        "intent": { "$ref": "#/$defs/DerivedEnumWithProv" },
        "highlights": { "$ref": "#/$defs/DerivedTextList" },
        "painPoints": { "$ref": "#/$defs/DerivedTextList" },
        "nextSteps": { "$ref": "#/$defs/DerivedTextList" }
      },
      "default": {}
    },
    "UiSignals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dealRiskLevel": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "UNKNOWN"], "default": "UNKNOWN" },
        "stage": { "type": "string", "default": "" },
        "progressPercent": { "type": "number", "minimum": 0, "maximum": 100, "default": 0 },
        "intentBadge": { "type": "string", "default": "" },
        "lastStabilizedAt": { "$ref": "#/$defs/TimestampMs" }
      },
      "default": {}
    },
    "SpeakerProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["speakerKey"],
      "properties": {
        "speakerKey": { "type": "string", "minLength": 1 },
        "labelCandidate": { "type": "string" },
        "labelAccepted": { "type": "string" },
        "prov": { "$ref": "#/$defs/Provenance" }
      }
    },
    "SpeakerRegistry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "speakers": { "type": "array", "items": { "$ref": "#/$defs/SpeakerProfile" }, "default": [] }
      },
      "default": {}
    },
    "MemoryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "summary", "prov"],
      "properties": {
        "key": { "type": "string" },
        "summary": { "type": "string" },
        "prov": { "$ref": "#/$defs/Provenance" }
      }
    },
    "MemoryBank": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "people": { "type": "array", "items": { "$ref": "#/$defs/MemoryItem" }, "default": [] },
        "topics": { "type": "array", "items": { "$ref": "#/$defs/MemoryItem" }, "default": [] }
      },
      "default": {}
    },
    "SuspiciousBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "reason"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string" },
        "detail": { "type": "string" }
      }
    },
    "IndexRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "endInclusive"],
      "properties": {
        "start": { "type": "integer", "minimum": 0 },
        "endInclusive": { "type": "integer", "minimum": 0 }
      }
    },
    "BatchPlanItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batchId", "editableRange", "examineRange"],
      "properties": {
        "batchId": { "type": "string" },
        "editableRange": { "$ref": "#/$defs/IndexRange" },
        "examineRange": { "$ref": "#/$defs/IndexRange" },
        "tailLookaheadEnabled": { "type": "boolean", "default": false }
      }
    },
    "PreprocessSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "first20Rendered": { "type": "array", "items": { "type": "string" }, "default": [] },
        "suspiciousBoundaries": { "type": "array", "items": { "$ref": "#/$defs/SuspiciousBoundary" }, "default": [] },
        "batchPlan": { "type": "array", "items": { "$ref": "#/$defs/BatchPlanItem" }, "default": [] },
        "prov": { "$ref": "#/$defs/Provenance" }
      },
      "default": {}
    },
    "ArtifactRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifactId": { "type": "string" },
        "hash": { "type": "string" },
        "createdAt": { "$ref": "#/$defs/TimestampMs" }
      },
      "default": {}
    },
    "AcceptedAndCandidate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accepted": { "type": "string" },
        "candidate": { "type": "string" },
        "candidateProv": { "$ref": "#/$defs/Provenance" }
      },
      "default": {}
    },
    "RenamingMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionTitle", "exportTitle"],
      "properties": {
        "sessionTitle": { "$ref": "#/$defs/AcceptedAndCandidate" },
        "exportTitle": { "$ref": "#/$defs/AcceptedAndCandidate" },
        "autoSessionRenameAppliedAt": { "$ref": "#/$defs/TimestampMs" },
        "autoExportRenameAppliedAt": { "$ref": "#/$defs/TimestampMs" },
        "userRenamedAt": { "$ref": "#/$defs/TimestampMs" },
        "exportTitleUserEditedAt": { "$ref": "#/$defs/TimestampMs" }
      }
    },
    "SessionState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "updatedAt", "renaming", "exportGate"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "updatedAt": { "$ref": "#/$defs/TimestampMs" },
        "renaming": { "$ref": "#/$defs/RenamingMetadata" },
        "exportGate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["smartAnalysisReady"],
          "properties": {
            "smartAnalysisReady": { "type": "boolean", "default": false },
            "smartAnalysisRef": { "$ref": "#/$defs/ArtifactRef" }
          }
        },
        "consent": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "externalMemory": { "type": "string", "enum": ["NONE", "QUERY_ONLY", "INGEST_SELECTED"], "default": "NONE" },
            "analytics": { "type": "string", "enum": ["NONE", "BASIC", "FULL"], "default": "NONE" }
          },
          "default": {}
        },
        "sessionSwitching": {
          "type": "object",
          "additionalProperties": true,
          "description": "Reserved for session management fields (pinned, archived, lastOpenedAt)."
        }
      }
    },
    "ExternalContextRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string" },
        "purpose": { "type": "string", "enum": ["CHAT_REPLY", "TRANSCRIPT_POLISH", "SMART_ANALYSIS", "EXPORT"] },
        "queryHash": { "type": "string" },
        "traceId": { "type": "string" },
        "itemIds": { "type": "array", "items": { "type": "string" }, "default": [] },
        "totalTokens": { "type": "integer", "minimum": 0 }
      },
      "default": {}
    },
    "PackRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packId": { "type": "string" },
        "version": { "type": "string" },
        "hash": { "type": "string" }
      },
      "default": {}
    },
    "ExternalKnowledgeAndStyle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "updatedAt", "enabled"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "updatedAt": { "$ref": "#/$defs/TimestampMs" },
        "enabled": { "type": "boolean", "default": false },
        "stylePack": { "$ref": "#/$defs/PackRef" },
        "knowledgePack": { "$ref": "#/$defs/PackRef" },
        "lastRetrieval": { "$ref": "#/$defs/ExternalContextRef" }
      }
    },
    "ConversationDerivedState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "updatedAt", "version", "rawSignals", "uiSignals", "preprocess", "smartAnalysisRefs"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "updatedAt": { "$ref": "#/$defs/TimestampMs" },
        "version": { "type": "integer", "minimum": 0 },
        "rawSignals": { "$ref": "#/$defs/RawSignals" },
        "uiSignals": { "$ref": "#/$defs/UiSignals" },
        "speakerRegistry": { "$ref": "#/$defs/SpeakerRegistry" },
        "memoryBank": { "$ref": "#/$defs/MemoryBank" },
        "preprocess": { "$ref": "#/$defs/PreprocessSnapshot" },
        "smartAnalysisRefs": { "type": "array", "items": { "$ref": "#/$defs/ArtifactRef" }, "default": [] },
        "externalContextRefs": { "type": "array", "items": { "$ref": "#/$defs/ExternalContextRef" }, "default": [] }
      }
    }
  }
}
