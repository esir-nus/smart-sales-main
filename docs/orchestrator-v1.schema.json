          "default": []
        },
        "keyPoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/M2BKeyPoint"
          },
          "default": []
        },
        "lastUpdatedAtMs": {
          "$ref": "#/$defs/TimestampMs"
        }
      }
