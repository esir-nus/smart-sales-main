<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 网络权限：LLM API 调用需要 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- 日历权限：Scheduler 任务同步需要 -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <!-- 闹钟权限：任务提醒需要 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- 通知权限：Android 13+ 需要 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 开机恢复：重启后重新注册闹钟 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 电池优化豁免：中国 OEM 闹钟可靠性 -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- 录音权限：手机端 ASR 录音 (L2 测试工具) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- 蓝牙权限：设备配对需要 -->
    <!-- Android 12+ (API 31+) 需要新权限 -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Android 11 及以下需要旧权限 -->
    <uses-permission android:name="android.permission.BLUETOOTH" 
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" 
        android:maxSdkVersion="30" />
    <!-- 部分设备需要位置权限才能扫描 BLE -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <application
        android:name=".PrismApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Prism"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Prism">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 下载保活前台服务 — 下载期间保持进程存活 -->
        <service
            android:name=".service.DownloadForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false" />

        <!-- 闹钟全屏 Activity — 半透明覆盖层 -->
        <activity
            android:name=".ui.alarm.AlarmActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Prism.Alarm"
            android:launchMode="singleTop"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:exported="false" />

        <!-- 任务提醒广播接收器 -->
        <receiver
            android:name=".data.scheduler.TaskReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.smartsales.prism.TASK_REMINDER" />
            </intent-filter>
        </receiver>

        <!-- 闹钟关闭广播接收器 — 处理滑动/按钮/点击关闭 -->
        <receiver
            android:name=".data.notification.AlarmDismissReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.smartsales.prism.ALARM_DISMISS" />
            </intent-filter>
        </receiver>

        <!-- 开机恢复广播接收器 — 重启后重新注册 AlarmManager 闹钟 -->
        <receiver
            android:name=".data.scheduler.BootCompletedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
