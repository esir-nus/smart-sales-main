{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Third-Party Integration Registry",
  "description": "Compact registry for third-party provider lanes (OSS/Tingwu/XFyun/Dashscope).",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "doc", "generatedFrom", "providers"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "minLength": 1 },
    "doc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "purpose", "audience", "scope", "nonGoals", "trustModel"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "audience": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "scope": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "nonGoals": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "trustModel": { "type": "string", "minLength": 1 }
      }
    },
    "generatedFrom": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repoRoot", "branch", "commit", "generatedAt"],
      "properties": {
        "repoRoot": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string", "minLength": 1 }
      }
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["oss", "tingwu", "xfyun", "dashscope"],
      "properties": {
        "oss": { "$ref": "#/definitions/ProviderEntry" },
        "tingwu": { "$ref": "#/definitions/ProviderEntry" },
        "xfyun": { "$ref": "#/definitions/ProviderEntry" },
        "dashscope": { "$ref": "#/definitions/ProviderEntry" }
      }
    }
  },
  "definitions": {
    "ProviderEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "primaryDocs", "capabilities", "endpoints", "guardrails", "evidencePointers"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ENABLED_DEFAULT", "DISABLED_DEFAULT", "OPTIONAL", "LEGACY", "UNKNOWN"]
        },
        "primaryDocs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
        "capabilities": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
        "endpoints": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
        "guardrails": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
        "evidencePointers": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] }
      }
    }
  }
}
