{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Third-Party Provider Registry Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["index", "providers"],
  "properties": {
    "index": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "schemaVersion", "purpose", "scope", "governedByDocs", "howToUse", "antiGoals"],
      "properties": {
        "current": { "type": "boolean" },
        "schemaVersion": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "governedByDocs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "howToUse": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "antiGoals": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
      }
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["oss", "tingwu", "xfyun", "dashscope"],
      "properties": {
        "oss": { "$ref": "#/$defs/ProviderEntry" },
        "tingwu": { "$ref": "#/$defs/ProviderEntry" },
        "xfyun": { "$ref": "#/$defs/ProviderEntry" },
        "dashscope": { "$ref": "#/$defs/ProviderEntry" }
      }
    }
  },
  "$defs": {
    "Endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "method"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "urlKey": { "type": "string", "minLength": 1 }
      },
      "anyOf": [
        { "required": ["path"] },
        { "required": ["urlKey"] }
      ]
    },
    "ProviderEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "displayName",
        "status",
        "purpose",
        "endpoints",
        "auth",
        "guardrails",
        "failureModes",
        "evidencePointers"
      ],
      "properties": {
        "displayName": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["enabled", "disabled"] },
        "purpose": { "type": "string", "minLength": 1 },
        "endpoints": { "type": "array", "items": { "$ref": "#/$defs/Endpoint" }, "minItems": 1 },
        "auth": { "type": "string", "minLength": 1 },
        "guardrails": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "failureModes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "evidencePointers": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "settingsKnobs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
