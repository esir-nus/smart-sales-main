!third_party/maven-repo/**/*.aar

# AAR/native library directories
app-core/libs/
app-core/libs

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
.gradle-user/
.gradle-local/
.gradle-tmp/
.gradle-temp/
.gradle-user-home/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# Gradle wrapper (keep the jar, ignore other wrapper files if any)
!gradle/wrapper/*.jar

# Local configuration file (sdk path, etc)
local.properties
platforms/harmony/tingwu-container/entry/src/main/ets/config/HarmonyContainerConfig.local.ets

# Proguard folder generated by Eclipse
proguard/

