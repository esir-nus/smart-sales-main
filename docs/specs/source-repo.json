{
  "index": {
    "current": true,
    "schemaVersion": "1.0.0",
    "purpose": "Third-party provider ledger for coding agents (providers only).",
    "scope": "OSS/Tingwu/XFyun/Dashscope only; no product specs or UX contracts.",
    "governedByDocs": [
      "docs/source-repo.schema.json",
      "docs/source-repo.json",
      "XFyun params only in docs/xfyun-asr-rest-api.md"
    ],
    "howToUse": [
      "start from provider entry, then follow evidencePointers",
      "use guardrails and failureModes to avoid guessing",
      "treat this as a ledger, not a product spec"
    ],
    "antiGoals": [
      "not architecture spec",
      "not UX spec",
      "not MetaHub schema"
    ]
  },
  "providers": {
    "oss": {
      "displayName": "Aliyun OSS",
      "status": "enabled",
      "purpose": "Upload audio and generate FileUrl for Tingwu.",
      "endpoints": [
        { "name": "PutObject", "method": "PUT", "urlKey": "oss.putObject" },
        { "name": "PresignUrl", "method": "GET", "urlKey": "oss.presignUrl" }
      ],
      "auth": "accessKey/secret from local.properties",
      "guardrails": ["Credentials required in local.properties."],
      "failureModes": ["Missing credentials", "Network timeout", "Access denied"],
      "evidencePointers": [
        "data/ai-core/src/main/java/com/smartsales/data/aicore/RealOssUploadClient.kt"
      ]
    },
    "tingwu": {
      "displayName": "Tingwu ASR",
      "status": "enabled",
      "purpose": "ASR transcription + summary + chapters.",
      "endpoints": [
        { "name": "CreateTask", "method": "PUT", "path": "/openapi/tingwu/v2/tasks" },
        { "name": "GetTaskStatus", "method": "GET", "path": "/openapi/tingwu/v2/tasks/{taskId}" },
        { "name": "GetTaskResult", "method": "GET", "path": "/openapi/tingwu/v2/tasks/{taskId}/transcription" }
      ],
      "auth": "appKey + accessKey/secret (signature)",
      "guardrails": ["Default lane uses OSS FileUrl."],
      "failureModes": ["Rate limit", "Timeout", "Provider error"],
      "evidencePointers": [
        "data/ai-core/src/main/java/com/smartsales/data/aicore/RealTingwuCoordinator.kt",
        "data/ai-core/src/main/java/com/smartsales/data/aicore/tingwu/TingwuApi.kt"
      ]
    },
    "xfyun": {
      "displayName": "XFyun ASR",
      "status": "disabled",
      "purpose": "ASR transfer-only lane (gated).",
      "endpoints": [
        { "name": "Upload", "method": "POST", "path": "/v2/upload" },
        { "name": "GetResult", "method": "GET", "path": "/v2/getResult" }
      ],
      "auth": "signature + accessKey/secret",
      "guardrails": ["transfer-only; translate/predict/analysis disabled by default."],
      "failureModes": ["Rate limit (429)", "Signature mismatch", "Invalid params"],
      "evidencePointers": [
        "docs/xfyun-asr-rest-api.md",
        "data/ai-core/src/main/java/com/smartsales/data/aicore/xfyun/XfyunAsrApi.kt",
        "data/ai-core/src/main/java/com/smartsales/data/aicore/xfyun/XfyunAsrCoordinator.kt"
      ]
    },
    "dashscope": {
      "displayName": "DashScope LLM",
      "status": "enabled",
      "purpose": "LLM chat/completions for analysis features.",
      "endpoints": [
        { "name": "Generate", "method": "POST", "urlKey": "dashscope.generate" }
      ],
      "auth": "apiKey",
      "guardrails": ["Streaming gated by config."],
      "failureModes": ["Rate limit", "Network error", "Auth error"],
      "evidencePointers": [
        "data/ai-core/src/main/java/com/smartsales/data/aicore/DashscopeAiChatService.kt",
        "data/ai-core/src/main/java/com/smartsales/data/aicore/DashscopeClient.kt"
      ]
    }
  }
}
